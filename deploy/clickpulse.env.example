# ClickHouse connection string
CLICKHOUSE_DSN=clickhouse://clickpulse:password@localhost:9000/default?secure=false

# HTTP metrics server port
METRICS_PORT=9188

# Poll interval
POLL_INTERVAL=5s

# Slow query threshold
SLOW_QUERY_THRESHOLD=5s

# Regression detection
REGRESSION_THRESHOLD=2.0
STMT_LIMIT=50

# Alerting (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# ALERT_WEBHOOK_URL=
# ALERT_COOLDOWN=5m

# Grafana annotations (optional)
# GRAFANA_URL=
# GRAFANA_TOKEN=
# GRAFANA_DASHBOARD_UID=
