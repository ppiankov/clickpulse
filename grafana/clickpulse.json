{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "clickpulse — ClickHouse Health",
  "uid": "clickpulse",
  "version": 1,
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "ClickHouse Up",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "targets": [{ "expr": "clickhouse_up", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }, "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }] } }
    },
    {
      "title": "Active Queries",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "targets": [{ "expr": "clickhouse_active_queries", "legendFormat": "" }]
    },
    {
      "title": "Active Merges",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "targets": [{ "expr": "clickhouse_merges_active", "legendFormat": "" }]
    },
    {
      "title": "Replica Lag",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "targets": [{ "expr": "clickhouse_replica_lag_seconds", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 10, "color": "yellow" }, { "value": 30, "color": "red" }] } } }
    },
    {
      "title": "Connections",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "targets": [{ "expr": "clickhouse_connections", "legendFormat": "" }]
    },
    {
      "title": "Memory",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "targets": [{ "expr": "clickhouse_memory_tracking_bytes", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Scrape Duration",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "targets": [{ "expr": "clickhouse_scrape_duration_seconds", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Scrape Errors",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "targets": [{ "expr": "rate(clickhouse_scrape_errors_total[5m])", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "err/s" } }
    },
    {
      "title": "Queries",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Queries by Type",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "clickhouse_queries_by_type", "legendFormat": "{{ type }}" }]
    },
    {
      "title": "Slow & Waiting Queries",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "clickhouse_slow_queries", "legendFormat": "slow" },
        { "expr": "clickhouse_waiting_queries", "legendFormat": "waiting" },
        { "expr": "clickhouse_longest_query_seconds", "legendFormat": "longest (s)" }
      ]
    },
    {
      "title": "Merges & Mutations",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "title": "Merge Pressure",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        { "expr": "clickhouse_merges_active", "legendFormat": "active" },
        { "expr": "clickhouse_merge_progress", "legendFormat": "avg progress" }
      ]
    },
    {
      "title": "Mutations",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        { "expr": "clickhouse_mutations_active", "legendFormat": "active" },
        { "expr": "clickhouse_mutations_stuck", "legendFormat": "stuck" }
      ]
    },
    {
      "title": "Replication",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "title": "Replica Queue Size",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [{ "expr": "clickhouse_replica_queue_size", "legendFormat": "{{ database }}.{{ table }}" }]
    },
    {
      "title": "Replica Lag & Readonly",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "clickhouse_replica_lag_seconds", "legendFormat": "lag" },
        { "expr": "sum(clickhouse_replica_readonly)", "legendFormat": "readonly tables" }
      ]
    },
    {
      "title": "Replication Discrepancies",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "targets": [
        { "expr": "clickhouse_replication_part_count_diff", "legendFormat": "part diff {{ database }}.{{ table }}" },
        { "expr": "clickhouse_replication_leaderless_tables", "legendFormat": "leaderless {{ database }}.{{ table }}" },
        { "expr": "clickhouse_replication_unreplicated_tables", "legendFormat": "unreplicated {{ database }}.{{ table }}" }
      ]
    },
    {
      "title": "Parts & Storage",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": false
    },
    {
      "title": "Parts per Partition (Top 10)",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "targets": [{ "expr": "topk(10, clickhouse_parts_per_partition)", "legendFormat": "{{ database }}.{{ table }}/{{ partition }}" }]
    },
    {
      "title": "Disk Usage",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "targets": [
        { "expr": "clickhouse_disk_used_ratio", "legendFormat": "{{ disk }} used" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.8, "color": "yellow" }, { "value": 0.95, "color": "red" }] } } }
    },
    {
      "title": "Keeper & DDL",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "title": "Keeper Health",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "targets": [
        { "expr": "clickhouse_keeper_outstanding_requests", "legendFormat": "outstanding" },
        { "expr": "clickhouse_keeper_znode_count", "legendFormat": "znodes" },
        { "expr": "clickhouse_keeper_latency_seconds", "legendFormat": "latency" }
      ]
    },
    {
      "title": "DDL Queue",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "targets": [
        { "expr": "clickhouse_ddl_queue_size", "legendFormat": "queue size" },
        { "expr": "clickhouse_ddl_queue_stuck", "legendFormat": "stuck" },
        { "expr": "clickhouse_ddl_oldest_entry_seconds", "legendFormat": "oldest (s)" }
      ]
    },
    {
      "title": "Query Regressions",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 58 },
      "collapsed": false
    },
    {
      "title": "Regressions Detected",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 59 },
      "targets": [{ "expr": "clickhouse_query_regressions", "legendFormat": "regressions" }]
    },
    {
      "title": "Throughput",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 59 },
      "targets": [
        { "expr": "rate(clickhouse_inserted_rows_total[5m])", "legendFormat": "inserts/s" },
        { "expr": "rate(clickhouse_selected_rows_total[5m])", "legendFormat": "selects/s" }
      ]
    }
  ]
}
