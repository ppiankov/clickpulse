{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "clickpulse — ClickHouse Health",
  "uid": "clickpulse",
  "version": 2,
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(clickhouse_up, service)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(clickhouse_up{service=~\"$service\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "ClickHouse Up",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "targets": [{ "expr": "clickhouse_up{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }}" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }, "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }] } }
    },
    {
      "title": "Active Queries",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "targets": [{ "expr": "sum(clickhouse_active_queries{service=~\"$service\", instance=~\"$instance\"})", "legendFormat": "" }]
    },
    {
      "title": "Active Merges",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "targets": [{ "expr": "sum(clickhouse_merges_active{service=~\"$service\", instance=~\"$instance\"})", "legendFormat": "" }]
    },
    {
      "title": "Replica Lag",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "targets": [{ "expr": "max(clickhouse_replica_lag_seconds{service=~\"$service\", instance=~\"$instance\"})", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 10, "color": "yellow" }, { "value": 30, "color": "red" }] } } }
    },
    {
      "title": "Connections",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "targets": [{ "expr": "sum(clickhouse_connections{service=~\"$service\", instance=~\"$instance\"})", "legendFormat": "" }]
    },
    {
      "title": "Memory",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "targets": [{ "expr": "sum(clickhouse_memory_tracking_bytes{service=~\"$service\", instance=~\"$instance\"})", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Scrape Duration",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "targets": [{ "expr": "max(clickhouse_scrape_duration_seconds{service=~\"$service\", instance=~\"$instance\"})", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Scrape Errors",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "targets": [{ "expr": "sum(rate(clickhouse_scrape_errors_total{service=~\"$service\", instance=~\"$instance\"}[5m]))", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "err/s" } }
    },
    {
      "title": "Queries",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Queries by Type",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "clickhouse_queries_by_type{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} {{ type }}" }]
    },
    {
      "title": "Slow & Waiting Queries",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "clickhouse_slow_queries{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} slow" },
        { "expr": "clickhouse_waiting_queries{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} waiting" },
        { "expr": "clickhouse_longest_query_seconds{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} longest (s)" }
      ]
    },
    {
      "title": "Merges & Mutations",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "title": "Merge Pressure",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        { "expr": "clickhouse_merges_active{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} active" },
        { "expr": "clickhouse_merge_progress{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} avg progress" }
      ]
    },
    {
      "title": "Mutations",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        { "expr": "clickhouse_mutations_active{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} active" },
        { "expr": "clickhouse_mutations_stuck{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} stuck" }
      ]
    },
    {
      "title": "Replication",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "title": "Replica Queue Size",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [{ "expr": "clickhouse_replica_queue_size{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} {{ database }}.{{ table }}" }]
    },
    {
      "title": "Replica Lag & Readonly",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "clickhouse_replica_lag_seconds{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} lag" },
        { "expr": "sum by (instance) (clickhouse_replica_readonly{service=~\"$service\", instance=~\"$instance\"})", "legendFormat": "{{ instance }} readonly" }
      ]
    },
    {
      "title": "Replication Discrepancies",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "targets": [
        { "expr": "clickhouse_replication_part_count_diff{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} part diff {{ database }}.{{ table }}" },
        { "expr": "clickhouse_replication_leaderless_tables{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} leaderless {{ database }}.{{ table }}" },
        { "expr": "clickhouse_replication_unreplicated_tables{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} unreplicated {{ database }}.{{ table }}" }
      ]
    },
    {
      "title": "Parts & Storage",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": false
    },
    {
      "title": "Parts per Partition (Top 10)",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "targets": [{ "expr": "topk(10, clickhouse_parts_per_partition{service=~\"$service\", instance=~\"$instance\"})", "legendFormat": "{{ instance }} {{ database }}.{{ table }}/{{ partition }}" }]
    },
    {
      "title": "Disk Usage",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "targets": [
        { "expr": "clickhouse_disk_used_ratio{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} {{ disk }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.8, "color": "yellow" }, { "value": 0.95, "color": "red" }] } } }
    },
    {
      "title": "Keeper & DDL",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "title": "Keeper Health",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "targets": [
        { "expr": "clickhouse_keeper_outstanding_requests{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ keeper }} outstanding" },
        { "expr": "clickhouse_keeper_znode_count{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ keeper }} znodes" },
        { "expr": "clickhouse_keeper_latency_seconds{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ keeper }} latency" }
      ]
    },
    {
      "title": "DDL Queue",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "targets": [
        { "expr": "clickhouse_ddl_queue_size{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} queue size" },
        { "expr": "clickhouse_ddl_queue_stuck{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} stuck" },
        { "expr": "clickhouse_ddl_oldest_entry_seconds{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} oldest (s)" }
      ]
    },
    {
      "title": "Query Regressions",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 58 },
      "collapsed": false
    },
    {
      "title": "Regressions Detected",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 59 },
      "targets": [{ "expr": "clickhouse_query_regressions{service=~\"$service\", instance=~\"$instance\"}", "legendFormat": "{{ instance }} regressions" }]
    },
    {
      "title": "Throughput",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 59 },
      "targets": [
        { "expr": "sum by (instance) (rate(clickhouse_inserted_rows_total{service=~\"$service\", instance=~\"$instance\"}[5m]))", "legendFormat": "{{ instance }} inserts/s" },
        { "expr": "sum by (instance) (rate(clickhouse_selected_rows_total{service=~\"$service\", instance=~\"$instance\"}[5m]))", "legendFormat": "{{ instance }} selects/s" }
      ]
    }
  ]
}
